# Alpaca paper account credentials. Either naming convention works.
APCA_API_KEY_ID=your_paper_key_id
APCA_API_SECRET_KEY=your_paper_secret_key
ALPACA_API_KEY=your_paper_key_id
ALPACA_SECRET_KEY=your_paper_secret_key
APCA_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# QSentia sizing baseline.
MODEL_NOTIONAL=1000000
DEFAULT_ACCOUNT_VALUE=1000000

# Safety switch. Keep false until dry-run outputs look correct.
EXECUTE_PAPER_ORDERS=false
SUBMIT_ORDERS=false

# Emergency kill switch: if true, all target weights become zero.
STRATEGY_KILL_SWITCH=false
